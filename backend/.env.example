# MLB Predictor Engine - Environment Variables Example

# Supabase Configuration
# You can find these in your Supabase project settings under API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key

# Security
# This secret must match the CRON_SECRET header sent by Vercel or your cron runner
CRON_SECRET=your_super_secret_cron_token_here

# Model Parameters (Optional - Defaults are used if not provided)
# The league average ERA used as a baseline for calculations
SCORE_LG_ERA=4.2
